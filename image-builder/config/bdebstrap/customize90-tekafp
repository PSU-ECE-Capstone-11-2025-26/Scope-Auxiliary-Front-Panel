#!/bin/bash
set -eu

rootfs=$1
src="${SRCROOT:-${IGTOP}}/packages"

shopt -s nullglob
wheels=("$src"/*.whl)
[[ ${#wheels[@]} -gt 0 ]] || { echo "customize90-tekafp: no wheel found in $src" >&2; exit 1; }

tmpdir=$(mktemp -d "$rootfs/tmp/pyvisa.XXXXXX")
trap 'rm -rf "$tmpdir"' EXIT
chroot_tmp="/tmp/$(basename "$tmpdir")"
chroot_wheels=()
for w in "${wheels[@]}"; do
    cp "$w" "$tmpdir/"
    chroot_wheels+=("$chroot_tmp/$(basename "$w")")
done

chroot "$rootfs" groupadd -f afpusb
chroot "$rootfs" usermod -aG afpusb,dialout tek

chroot "$rootfs" /usr/bin/pip3 install --break-system-packages --no-cache-dir "${chroot_wheels[@]}"

chroot "$rootfs" systemctl mask getty@tty1.service
chroot "$rootfs" systemctl mask serial-getty@ttyAMA0

"$BDEBSTRAP_HOOKS/enable-units" "$rootfs" seatd
"$BDEBSTRAP_HOOKS/enable-units" "$rootfs" set-hostname
"$BDEBSTRAP_HOOKS/enable-units" "$rootfs" greetd
"$BDEBSTRAP_HOOKS/enable-units" "$rootfs" resize-rootfs
"$BDEBSTRAP_HOOKS/enable-units" "$rootfs" tekafp
"$BDEBSTRAP_HOOKS/enable-units" "$rootfs" regenerate-ssh-host-keys
