#!/bin/bash
set -eu

rootfs=$1
cmdline=$rootfs/boot/firmware/cmdline.txt
config=$rootfs/boot/firmware/config.txt

# Always free the primary UART: strip the serial console from it.
sed -i -E 's/\bconsole=serial0,[0-9]+\s*//' "$cmdline"

# Always enable the primary UART (stable clock) and expose UART2 on GPIO 0/1.
cat >> "$config" <<'EOF'

# AFP: primary UART reserved for attached hardware; UART2 available for debug console.
enable_uart=1
dtoverlay=disable-bt
dtoverlay=uart2
EOF

# Debug builds: route the kernel console to UART2 (ttyAMA1).
if [[ "${IGconf_afp_debug:-n}" = "y" ]]; then
    sed -i -E 's/(\s*)$/ console=ttyAMA1,115200\1/' "$cmdline"
fi
